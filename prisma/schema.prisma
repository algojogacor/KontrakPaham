// KontrakPaham — Contract analysis platform (Bahasa Indonesia)
// Prisma schema (SQLite)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  displayName  String?
  plan         String   @default("FREE") // FREE | LITE | PRO | ADMIN
  planExpiresAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  analyses         Analysis[]
  analysisChatThreads AnalysisChatThread[]
  analysisChatMessages AnalysisChatMessage[]
  quotas           Quota[]
  passwordResets   PasswordResetToken[]
  auditLogs        AuditLog[]
  createdLicenses  LicenseCode[] @relation("LicenseCreator")
  redeemedLicenses LicenseCode[] @relation("LicenseRedeemer")
}

model LicenseCode {
  id              String    @id @default(cuid())
  codeHash        String    @unique
  codePrefix      String
  plan            String    // LITE | PRO
  durationMonths  Int       @default(1)
  analysesLimit   Int
  maxUses         Int       @default(1)
  uses            Int       @default(0)
  note            String?
  expiresAt       DateTime?
  redeemedAt      DateTime?
  createdAt       DateTime  @default(now())
  createdById     String?
  redeemedById    String?

  createdBy  User? @relation("LicenseCreator", fields: [createdById], references: [id], onDelete: SetNull)
  redeemedBy User? @relation("LicenseRedeemer", fields: [redeemedById], references: [id], onDelete: SetNull)

  @@index([plan])
  @@index([createdAt])
  @@index([redeemedById])
}

model LlmProvider {
  id              String    @id @default(cuid())
  name            String
  provider        String
  baseUrl         String
  apiKey          String
  model           String
  enabled         Boolean   @default(true)
  priority        Int       @default(10)
  useJsonResponse Boolean   @default(true)
  maxTokens       Int       @default(4096)
  temperature     Float     @default(0.1)
  timeoutMs       Int       @default(90000)
  lastStatus      String?
  lastLatencyMs   Int?
  lastTestedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([enabled, priority])
}

model LegalReferenceCache {
  id              String   @id @default(cuid())
  cacheKey        String   @unique
  normalizedQuery String
  query           String
  effort          String
  content         String
  contentBytes    Int      @default(0)
  sources         String?
  latencyMs       Int?
  hitCount        Int      @default(0)
  lastHitAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([effort, updatedAt])
}

model Analysis {
  id           String   @id @default(cuid())
  userId       String
  title        String
  sourceType   String // TEXT | PDF | DOCX
  fileName     String?
  language     String   @default("id")
  charCount    Int      @default(0)
  summary      String?
  overallRisk  String?  // RENDAH | SEDANG | TINGGI | KRITIS
  riskScore    Int?     // 0-100
  status       String   @default("COMPLETED") // PENDING | COMPLETED | FAILED
  errorMessage String?
  modelUsed    String?
  researchEffort String?
  researchQuery String?
  researchLatencyMs Int?
  researchContent String?
  researchSources String?
  shareToken   String?  @unique  // Read-only public share token
  textHash     String?
  cacheKey     String?
  cacheHit     Boolean  @default(false)
  cacheSourceId String?
  analysisVersion String?
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  findings Finding[]
  chatThreads AnalysisChatThread[]
  chatMessages AnalysisChatMessage[]

  @@index([userId, createdAt])
  @@index([userId, cacheKey, status])
  @@index([userId, textHash, status])
}

model AnalysisChatThread {
  id         String   @id @default(cuid())
  analysisId String
  userId     String
  title      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AnalysisChatMessage[]

  @@unique([analysisId, userId])
  @@index([userId, updatedAt])
}

model AnalysisChatMessage {
  id         String   @id @default(cuid())
  threadId   String
  analysisId String
  userId     String
  role       String   // user | assistant
  content    String
  modelUsed  String?
  createdAt  DateTime @default(now())

  thread   AnalysisChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  analysis Analysis           @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([analysisId, createdAt])
  @@index([userId, createdAt])
}

model Finding {
  id              String  @id @default(cuid())
  analysisId      String
  category        String // e.g. JANGKA_WAKTU, DENDA, KLAUSUL_SEPIHAK, etc.
  categoryLabel   String
  severity        String // RENDAH | SEDANG | TINGGI | KRITIS
  confidence      Int    // 0-100
  urgency         String // INFO | PERHATIAN | PERLU_TINDAKAN
  originalClause  String
  plainTranslation String
  explanation     String
  recommendation  String
  actionType      String // INFO_UMUM | BUTUH_NASIHAT
  location        String?

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model Quota {
  id             String   @id @default(cuid())
  userId         String
  month          Int
  year           Int
  analysesUsed   Int      @default(0)
  analysesLimit  Int      @default(3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ip        String?
  meta      String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
}

model LegalDocument {
  id              String   @id @default(cuid())
  title           String
  type            String
  number          String?
  year            Int?
  jurisdiction    String   @default("ID")
  sourceUrl       String?
  sourceHost      String?
  status          String   @default("ACTIVE")
  driveFileId     String?
  contentHash     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  articles LegalArticle[]

  @@index([type, year])
  @@index([sourceHost])
}

model LegalArticle {
  id              String   @id @default(cuid())
  documentId      String
  articleNumber   String
  title           String?
  text            String
  plainSummary    String?
  tags            String
  normalizedText  String
  sourceUrl       String?
  contentHash     String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  document LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  indexRows LegalArticleIndex[]

  @@index([documentId, articleNumber])
}

model LegalArticleIndex {
  id         String @id @default(cuid())
  articleId  String
  token      String
  tag        String?
  weight     Int    @default(1)

  article LegalArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([tag])
  @@unique([articleId, token])
}

